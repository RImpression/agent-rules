{
  "name": "agent-rules",
  "version": "0.1.0",
  "description": "CLI tool to generate AI-readable project specifications (.agents/ directory)",
  "type": "module",
  "bin": {
    "arules": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "agent", "rules", "cli", "specification"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
